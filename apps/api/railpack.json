{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.11"
  },
  "buildAptPackages": [],
  "steps": {
    "install": {
      "commands": [
        "pip install --no-cache-dir -r requirements.txt"
      ]
    }
  },
  "deploy": {
    "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT"
  }
}
