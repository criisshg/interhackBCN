# Pulse · variables de entorno (plantilla local)
# Copia este fichero a `.env` y rellena los valores reales SOLO en tu máquina.
# Render y Vercel tienen sus propias variables en sus paneles; no leen tu `.env` local.
#
# IMPORTANTE: `.env` está en .gitignore. NUNCA commitees secretos.

# =========================================================
# Postgres · usado por apps/api y apps/ml
# =========================================================
# Local (con Docker o instalación nativa):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulse
# Producción Render/Supabase:
# No pongas el valor real aquí. Añádelo en Render → Environment.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-eu-north-1.pooler.supabase.com:5432/postgres

# =========================================================
# Google Gemini · usado por apps/api/agent (P4 · Nig)
# =========================================================
# Genera tu key en https://aistudio.google.com/apikey
# NUNCA commitees el valor real — este fichero es plantilla.
GEMINI_API_KEY=your-gemini-key-here
# Modelo por defecto. Flash es rápido y maneja tool-use bien.
# Subir a gemini-2.5-pro si necesitamos razonamiento más fino.
GEMINI_MODEL=gemini-2.5-flash

# =========================================================
# ElevenLabs · usado por apps/api/routers/voice.py (opcional)
# =========================================================
# Si no se configura, /voice devolverá 503, pero la API y /chat seguirán funcionando.
ELEVENLABS_API_KEY=your-elevenlabs-key-here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# =========================================================
# CORS · API → Web
# =========================================================
# En local:
CORS_ORIGINS=http://localhost:3000
# En producción Render:
# CORS_ORIGINS=https://web-mocha-three-68.vercel.app,http://localhost:3000

# =========================================================
# API base URL · usado por el agente para llamar a sus tools
# =========================================================
API_BASE_URL=http://localhost:8000
# En Render:
# API_BASE_URL=https://interhackbcn.onrender.com

# =========================================================
# Web (Next.js) · apunta al backend
# =========================================================
# Lee desde apps/web/.env.local. setup.* lo copia ahí también.
NEXT_PUBLIC_API_URL=http://localhost:8000
# En Vercel:
# NEXT_PUBLIC_API_URL=https://interhackbcn.onrender.com

# =========================================================
# Opcionales
# =========================================================
# Nivel de log de la API
LOG_LEVEL=INFO
# Token estático para proteger endpoints sensibles (decisión de P2/P5)
# API_AUTH_TOKEN=
