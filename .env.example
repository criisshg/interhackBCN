# Pulse · variables de entorno (plantilla)
# Copia este fichero a `.env` y rellena los valores reales.
# El script setup.ps1 / setup.sh lo hace por ti.
#
# IMPORTANTE: `.env` está en .gitignore. NUNCA commitees secretos.

# =========================================================
# Postgres · usado por apps/api y apps/ml
# =========================================================
# Local (con Docker o instalación nativa):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulse
# Producción (Railway lo provee automáticamente):
# DATABASE_URL=postgresql://user:pass@host.railway.internal:5432/railway

# =========================================================
# Anthropic · usado por apps/api/agent (P4 · Nig)
# =========================================================
# Lo entrega el sponsor en kickoff. Mientras tanto, cualquier key personal sirve.
ANTHROPIC_API_KEY=sk-ant-api03-...
# Modelo por defecto. Bajar a haiku si la cuota es limitada.
ANTHROPIC_MODEL=claude-opus-4-7

# =========================================================
# CORS · API → Web
# =========================================================
# En local:
CORS_ORIGINS=http://localhost:3000
# En producción:
# CORS_ORIGINS=https://pulse-web.vercel.app

# =========================================================
# Web (Next.js) · apunta al backend
# =========================================================
# Lee desde apps/web/.env.local. setup.* lo copia ahí también.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Producción:
# NEXT_PUBLIC_API_URL=https://pulse-api.up.railway.app

# =========================================================
# Opcionales
# =========================================================
# Nivel de log de la API
LOG_LEVEL=INFO
# Token estático para proteger endpoints sensibles (decisión de P2/P5)
# API_AUTH_TOKEN=
