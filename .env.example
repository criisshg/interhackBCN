# Pulse · variables de entorno (plantilla)
# Copia este fichero a `.env` y rellena los valores reales.
# El script setup.ps1 / setup.sh lo hace por ti.
#
# IMPORTANTE: `.env` está en .gitignore. NUNCA commitees secretos.

# =========================================================
# Postgres · usado por apps/api y apps/ml
# =========================================================
# Local (con Docker o instalación nativa):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulse
# Producción (Render lo inyecta automáticamente desde el blueprint):
# DATABASE_URL=postgres://pulse:...@...frankfurt-postgres.render.com/pulse

# =========================================================
# Google Gemini · usado por apps/api/agent (P4 · Nig)
# =========================================================
# Genera tu key en https://aistudio.google.com/apikey
# NUNCA commitees el valor real — este fichero es plantilla.
GEMINI_API_KEY=your-gemini-key-here
# Modelo por defecto. Flash es rápido y maneja tool-use bien.
# Subir a gemini-2.5-pro si necesitamos razonamiento más fino.
GEMINI_MODEL=gemini-2.5-flash

# =========================================================
# CORS · API → Web
# =========================================================
# En local:
CORS_ORIGINS=http://localhost:3000
# En producción:
# CORS_ORIGINS=https://pulse-web.vercel.app

# =========================================================
# API base URL · usado por el agente para llamar a sus tools
# =========================================================
API_BASE_URL=http://localhost:8000

# =========================================================
# Web (Next.js) · apunta al backend
# =========================================================
# Lee desde apps/web/.env.local. setup.* lo copia ahí también.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Producción:
# NEXT_PUBLIC_API_URL=https://pulse-api.onrender.com

# =========================================================
# Opcionales
# =========================================================
# Nivel de log de la API
LOG_LEVEL=INFO
# Token estático para proteger endpoints sensibles (decisión de P2/P5)
# API_AUTH_TOKEN=
